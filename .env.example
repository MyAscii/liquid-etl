# Copy to .env and adjust. All values have defaults in docker-compose.yml.

# --- Chain selection ---
# elementsregtest = self-contained dev chain (use with: docker compose --profile regtest up)
# liquidv1        = Liquid mainnet (real history; set LIQUID_WAIT_FOR_SYNC=1)
CHAIN=elementsregtest

# --- elementsd release (see https://github.com/ElementsProject/elements/releases) ---
ELEMENTS_VERSION=23.2.4
# Optional strong pin: sha256 of elements-<version>-<arch>.tar.gz. Empty = verify against
# Blockstream's published SHA256SUMS only.
ELEMENTS_SHA256=

# --- Node RPC credentials ---
RPC_USER=liquid
RPC_PASSWORD=liquid

# --- Postgres ---
POSTGRES_USER=liquidetl
POSTGRES_PASSWORD=liquidetl
POSTGRES_DB=liquidetl
POSTGRES_HOST_PORT=5433

# Expose the node RPC on the host (debugging). Set empty to keep it internal-only.
ELEMENTS_HOST_PORT=7041

# --- Parser pipeline ---
# backfill_then_stream (default) | backfill | stream
LIQUID_PIPELINE_MODE=backfill_then_stream
LIQUID_START_BLOCK=0
# 1 = wait until the node finishes initial block download before backfilling (mainnet).
LIQUID_WAIT_FOR_SYNC=0
LIQUID_ENRICH=0

# --- Backfill tuning (speed) ---
LIQUID_CONFLICT_STRATEGY=ignore
LIQUID_FAST_LOCAL=1
LIQUID_RPC_BATCH_SIZE=200
LIQUID_CHUNK_SIZE=500
LIQUID_PREFETCH=8

# --- Stream tuning ---
LIQUID_STREAM_BATCH_SIZE=100
LIQUID_POLL_INTERVAL=2
LIQUID_LAG=0

# --- Regtest miner ---
MINE_INITIAL_BLOCKS=200
MINE_INTERVAL=5
